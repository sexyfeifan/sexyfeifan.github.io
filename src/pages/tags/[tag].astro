---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = [...new Set(posts.flatMap(post => post.data.tags))];
  
  return tags.map(tag => ({
    params: { tag },
    props: { 
      tag,
      posts: posts
        .filter(post => post.data.tags.includes(tag) && !post.data.draft)
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    },
  }));
}

const { tag, posts } = Astro.props;
---

<Base title={`#${tag} - 我的无人岛`} description={`#${tag} 标签下的所有文章`}>
  <section class="tag-page">
    <h1 class="page-title">
      <span class="title-emoji">🏷️</span>
      #{tag}
    </h1>
    <p class="page-subtitle">共 {posts.length} 篇文章</p>

    <div class="posts-list">
      {posts.map(post => (
        <article class="post-item">
          <div class="item-date">
            {post.data.pubDate.toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: '2-digit',
              day: '2-digit'
            })}
          </div>
          <div class="item-content">
            <span class="item-cover">{post.data.cover}</span>
            <div class="item-info">
              <h3 class="item-title">
                <a href={`/blog/${post.slug}`}>{post.data.title}</a>
              </h3>
              <p class="item-desc">{post.data.description}</p>
              <div class="item-meta">
                <span class="item-category">{post.data.category}</span>
                <span class="item-read-time">{post.data.readTime}</span>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="back-link">
      <a href="/tags">← 返回标签</a>
    </div>
  </section>
</Base>

<style>
  .tag-page {
    max-width: 800px;
    margin: 0 auto;
  }

  .page-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .title-emoji {
    font-size: 2rem;
  }

  .page-subtitle {
    color: var(--text-light);
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .post-item {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border-radius: var(--radius);
    border: 2px solid var(--border);
    transition: all 0.2s;
  }

  .post-item:hover {
    border-color: var(--primary);
    transform: translateX(4px);
  }

  .item-date {
    font-size: 0.9rem;
    color: var(--text-light);
    font-weight: 600;
    min-width: 80px;
    padding-top: 0.25rem;
  }

  .item-content {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex: 1;
  }

  .item-cover {
    font-size: 2rem;
  }

  .item-info {
    flex: 1;
  }

  .item-title {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .item-title a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .item-title a:hover {
    color: var(--primary);
  }

  .item-desc {
    color: var(--text-light);
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .item-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
    color: var(--text-light);
  }

  .item-category {
    background: var(--primary-light);
    color: var(--primary);
    padding: 0.15rem 0.5rem;
    border-radius: 12px;
  }

  .back-link {
    text-align: center;
  }

  .back-link a {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
  }

  .back-link a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 1.8rem;
    }

    .post-item {
      flex-direction: column;
      gap: 0.75rem;
    }

    .item-content {
      flex-direction: column;
    }
  }
</style>
