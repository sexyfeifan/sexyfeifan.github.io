---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = posts.reduce((acc, post) => {
  const category = post.data.category;
  if (!acc[category]) acc[category] = [];
  acc[category].push(post);
  return acc;
}, {} as Record<string, typeof posts>);

const categoryNames = Object.keys(categories).sort((a, b) => 
  categories[b].length - categories[a].length
);
---

<Base title="分类 - 我的无人岛" description="文章分类浏览">
  <section class="categories">
    <h1 class="page-title">
      <span class="title-emoji">📂</span>
      文章分类
    </h1>
    <p class="page-subtitle">共 {categoryNames.length} 个分类</p>

    <div class="categories-grid">
      {categoryNames.map(name => (
        <div class="category-card">
          <h2 class="category-name">
            <a href={`/categories/${name}`}>{name}</a>
          </h2>
          <span class="category-count">{categories[name].length} 篇</span>
          <div class="category-posts">
            {categories[name].slice(0, 3).map(post => (
              <a href={`/blog/${post.slug}`} class="category-post">
                <span class="post-cover">{post.data.cover}</span>
                <span class="post-title">{post.data.title}</span>
              </a>
            ))}
            {categories[name].length > 3 && (
              <span class="more">还有 {categories[name].length - 3} 篇...</span>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .categories {
    max-width: 1000px;
    margin: 0 auto;
  }

  .page-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .title-emoji {
    font-size: 2rem;
  }

  .page-subtitle {
    color: var(--text-light);
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .category-card {
    background: var(--bg-card);
    border-radius: var(--radius);
    padding: 1.5rem;
    border: 2px solid var(--border);
    transition: all 0.2s;
  }

  .category-card:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
  }

  .category-name {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }

  .category-name a {
    color: var(--text);
    text-decoration: none;
  }

  .category-name a:hover {
    color: var(--primary);
  }

  .category-count {
    display: inline-block;
    background: var(--primary-light);
    color: var(--primary);
    padding: 0.2rem 0.6rem;
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .category-posts {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .category-post {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.2s;
  }

  .category-post:hover {
    background: var(--primary-light);
  }

  .post-cover {
    font-size: 1.2rem;
  }

  .post-title {
    font-size: 0.9rem;
    font-weight: 600;
  }

  .more {
    font-size: 0.85rem;
    color: var(--text-light);
    padding: 0.5rem;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 1.8rem;
    }

    .categories-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
